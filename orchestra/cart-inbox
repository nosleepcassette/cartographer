#!/usr/bin/env zsh
# maps · cassette.help · MIT
set -euo pipefail
ROOT=${0:A:h:h}
cd "$ROOT"
PYTHONPATH="$ROOT${PYTHONPATH:+:$PYTHONPATH}" python3 - "${1:-20}" <<'PY'
from cartographer.agent_memory import pending_learning_blocks
from cartographer.config import atlas_root, load_config
import sys
count = max(1, int(sys.argv[1])); root = atlas_root(load_config())
rows = pending_learning_blocks(root)[:count]
print("\n".join(f"{item.block_id} | {item.agent or 'unknown'} | {item.topic} | {item.attrs.get('date', 'unknown')} | {' '.join(item.content.split())}" for item in rows) or "no pending learnings")
PY
